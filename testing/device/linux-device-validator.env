# Optional display name printed at startup.
BOARD_NAME=example-board

# Optional GPIO lines to read. Format:
#   gpiochipN:offset
#   gpiochipN:offset=low
#   gpiochipN:offset=high
GPIO_READ_LINES=

# Optional UART ports to open for configuration reads.
UART_PORTS=

# Optional USB interface target to claim/release.
# Format: bus:ports:interface where ports is dot-separated.
# Example: USB_TARGET=1:2.3:0
USB_TARGET=
USB_ALT_SETTING=

# Optional Bosch IMU target.
# Prefer BMI088_* keys. BMI055_* aliases are also accepted.
BMI088_BUS=
BMI088_ACCEL_ADDRESS=0x18
BMI088_GYRO_ADDRESS=0x68
BMI088_LABEL=bmi-imu
# Optional interrupt lines:
# BMI088_ACCEL_INT=gpiochip4:23
# BMI088_GYRO_INT=gpiochip4:24

# Optional BMM150 target.
BMM150_BUS=
BMM150_ADDRESS=0x10
BMM150_LABEL=bmm150

# Optional power sensor target.
# POWER_KIND must be one of: ina226, ina238, ina260
POWER_KIND=
POWER_BUS=
POWER_ADDRESS=0x40
POWER_LABEL=power
# Required for INA226 and INA238 where noted:
POWER_SHUNT_RESISTANCE_OHMS=
POWER_MAX_CURRENT_A=
