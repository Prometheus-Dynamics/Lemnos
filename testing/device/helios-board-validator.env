# Live Helios board sensor targets derived from:
#   HeliOS/gaia/assets/services/helios-peripherals/sensors.toml

BOARD_NAME=helios

# Safe read-only GPIO checks on the live board using already-exported sysfs
# lines:
#   gpiochip569:16 -> GPIO16
#   gpiochip569:20 -> GPIO20
GPIO_READ_LINES=gpiochip569:16,gpiochip569:20

# Kernel-managed LED class targets:
#   ACT currently tracks the mmc0 trigger
#   PWR is usually on the none trigger
LED_TARGETS=ACT=mmc0,PWR=none

# Kernel-managed fan target through hwmon/pwm-fan:
#   hwmon3 currently exposes pwmfan with pwm1=0 and pwm1_enable=1
FAN_TARGETS=hwmon3:0:1

# Raw SPI target exposed through spidev on the board.
SPI_TARGETS=10:0

UART_PORTS=
USB_TARGET=

BMI088_BUS=4
BMI088_ACCEL_ADDRESS=0x18
BMI088_GYRO_ADDRESS=0x68
BMI088_LABEL=imu

BMM150_BUS=1
BMM150_ADDRESS=0x10
BMM150_LABEL=mag

POWER_KIND=ina238
POWER_BUS=1
POWER_ADDRESS=0x40
POWER_LABEL=main-power
POWER_SHUNT_RESISTANCE_OHMS=0.010
